//- layout.pug
doctype html
html
    head
        title #{title || "My SpaceTraders Client"}
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1")
        style.
            :root {
                --bg-0: #eef2f7;
                --bg-1: #f8fafc;
                --ink-0: #0f172a;
                --ink-1: #334155;
                --ink-2: #64748b;
                --line: #d7e0ea;
                --card: #ffffff;
                --brand: #0f766e;
                --brand-strong: #115e59;
                --nav-bg: #0f172a;
            }

            * { box-sizing: border-box; }

            body {
                margin: 0;
                padding: 0;
                color: var(--ink-0);
                background:
                    radial-gradient(circle at 8% -12%, #dbeafe 0%, rgba(219, 234, 254, 0) 32%),
                    radial-gradient(circle at 92% -18%, #ccfbf1 0%, rgba(204, 251, 241, 0) 30%),
                    linear-gradient(180deg, var(--bg-1), var(--bg-0));
                font-family: "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
                min-height: 100vh;
            }

            .topbar {
                position: sticky;
                top: 0;
                z-index: 20;
                display: flex;
                gap: 10px;
                align-items: center;
                flex-wrap: wrap;
                background: var(--nav-bg);
                border-bottom: 1px solid rgba(255, 255, 255, 0.1);
                padding: 10px 16px;
                box-shadow: 0 6px 20px rgba(15, 23, 42, 0.2);
            }

            .topbar a {
                color: #dbeafe;
                text-decoration: none;
                font-size: 0.9rem;
                font-weight: 700;
                padding: 6px 10px;
                border-radius: 6px;
                border: 1px solid transparent;
                transition: background-color 0.15s ease, color 0.15s ease, border-color 0.15s ease;
            }

            .topbar a:hover,
            .topbar a.active {
                background: rgba(148, 163, 184, 0.18);
                border-color: rgba(148, 163, 184, 0.34);
                color: #ffffff;
            }

            .topbar-spacer {
                flex: 1 1 auto;
            }

            .topbar-stat {
                color: #e2e8f0;
                font-size: 0.84rem;
                font-weight: 700;
                padding: 4px 8px;
                border-radius: 999px;
                background: rgba(148, 163, 184, 0.2);
                border: 1px solid rgba(148, 163, 184, 0.3);
                white-space: nowrap;
            }

            .container {
                max-width: 1200px;
                margin: 0 auto;
                padding: 20px;
            }

            .global-banner-wrap {
                max-width: 1200px;
                margin: 12px auto 0;
                padding: 0 20px;
            }

            .global-banner {
                border-radius: 10px;
                padding: 10px 12px;
                border: 1px solid #f59e0b;
                background: #fffbeb;
                color: #92400e;
                display: flex;
                justify-content: space-between;
                align-items: center;
                gap: 10px;
                flex-wrap: wrap;
                font-size: 0.9rem;
                box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
            }

            .global-banner.danger {
                border-color: #ef4444;
                background: #fef2f2;
                color: #991b1b;
            }

            .global-banner a {
                text-decoration: none;
                font-weight: 700;
                color: inherit;
                border: 1px solid currentColor;
                border-radius: 999px;
                padding: 4px 9px;
            }

            .global-banner a:hover {
                background: rgba(255, 255, 255, 0.55);
            }

            .ship-card {
                background: var(--card);
                border-radius: 10px;
                border: 1px solid var(--line);
                padding: 15px;
                margin-bottom: 14px;
                box-shadow: 0 10px 26px rgba(15, 23, 42, 0.07);
            }

            .app-toast {
                position: fixed;
                left: 50%;
                bottom: 22px;
                transform: translateX(-50%);
                z-index: 40;
                min-width: min(540px, calc(100vw - 28px));
                max-width: min(640px, calc(100vw - 28px));
                padding: 12px 14px;
                border-radius: 12px;
                background: rgba(15, 23, 42, 0.94);
                color: #f8fafc;
                border: 1px solid rgba(148, 163, 184, 0.24);
                box-shadow: 0 18px 40px rgba(15, 23, 42, 0.28);
                font-size: 0.92rem;
                font-weight: 700;
                opacity: 1;
                transition: opacity 0.45s ease, transform 0.45s ease;
            }

            .app-toast.fade-out {
                opacity: 0;
                transform: translateX(-50%) translateY(10px);
            }

            button {
                margin-top: 5px;
            }

            @media (max-width: 680px) {
                .container {
                    padding: 14px;
                }
                .global-banner-wrap {
                    padding: 0 14px;
                }
                .topbar {
                    padding: 10px 12px;
                }
            }

    body
        //- Top Navigation Bar
        include topbar.pug

        if globalBanner
            .global-banner-wrap
                .global-banner(class=globalBanner.level === "danger" ? "danger" : "warning")
                    span= globalBanner.message
                    if globalBanner.ctaHref && globalBanner.ctaLabel
                        a(href=globalBanner.ctaHref)= globalBanner.ctaLabel

        //- Page-specific content inserted here
        .container
            block content

        if appToast && appToast.message
            .app-toast#appToast= appToast.message

        if appToast && appToast.message
            script.
                (() => {
                    const toast = document.getElementById("appToast");
                    if (!toast) {
                        return;
                    }

                    window.setTimeout(() => {
                        toast.classList.add("fade-out");
                    }, 2600);

                    window.setTimeout(() => {
                        toast.remove();
                    }, 3200);
                })();